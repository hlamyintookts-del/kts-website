---
// src/components/History.astro

// နှစ်အလိုက် ခွဲထားသော ဒေတာဖိုင်များကို လှမ်းယူခြင်း
import { data2019 } from '../data/history/2019.js';
import { data2020 } from '../data/history/2020.js';
import { data2021 } from '../data/history/2021.js';
import { data2022 } from '../data/history/2022.js';
import { data2023 } from '../data/history/2023.js';
import { data2024 } from '../data/history/2024.js';
import { data2025 } from '../data/history/2025.js';
import { data2026 } from '../data/history/2026.js';
import { data2027 } from '../data/history/2027.js';
// နောင်တွင် ဖိုင်အသစ်များဆောက်ပါက အောက်ပါအတိုင်း လာရောက် Import လုပ်ပါ
// import { data2020 } from '../data/history/2020.js';
// import { data2021 } from '../data/history/2021.js';

// ၉ နှစ်စာ စုစည်းမည့် Array (လောလောဆယ် ၂၀၁၉ ကို နမူနာထည့်ထားပြီး နောက်နှစ်များ တိုးလာပါက အောက်တွင် ထည့်ရုံပါပဲ)
const historyData = [
  data2019,
  data2020,
  data2021,
  data2022,
  data2023,
  data2024,
  data2025,
  data2026,
  data2027
];
---

<section 
  id="history" 
  class="py-24 bg-gray-50 dark:bg-[#0A0A0A] text-gray-900 dark:text-white transition-colors duration-300 min-h-screen"
  x-data="historyGallery"
  data-history={JSON.stringify(historyData)}
>
  <div class="max-w-7xl mx-auto px-4 md:px-6">
    
    <div class="text-center mb-16" x-show="view === 'years'" x-transition:enter="transition ease-out duration-500" x-transition:enter-start="opacity-0 translate-y-4" x-transition:enter-end="opacity-100 translate-y-0">
      <h2 class="text-3xl md:text-5xl font-bold mb-4">ကုမ္ပဏီ <span class="text-[#F5C518]">သမိုင်းကြောင်း</span></h2>
      <p class="text-gray-500 dark:text-gray-400 max-w-2xl mx-auto">Kilo Taxi ၏ ဖြတ်သန်းခဲ့သော ခြေလှမ်းများနှင့် အောင်မြင်မှု မှတ်တိုင်များကို ခုနှစ်အလိုက် လေ့လာကြည့်ရှုနိုင်ပါသည်။</p>
    </div>

    <div x-show="view !== 'years'" class="mb-10 flex flex-wrap items-center gap-4" style="display: none;" x-transition>
      <button @click="goBack()" class="flex items-center gap-2 px-4 py-2 bg-gray-200 dark:bg-white/5 hover:bg-[#F5C518] hover:text-black dark:hover:bg-[#F5C518] dark:text-white rounded-lg transition-colors border border-transparent dark:border-white/10 shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
        နောက်သို့
      </button>
      
      <div class="flex items-center text-lg md:text-2xl font-bold tracking-tight">
        <span x-text="activeYear?.year" class="text-[#F5C518]"></span>
        <span x-show="view === 'gallery'" class="mx-3 text-gray-400">/</span>
        <span x-show="view === 'gallery'" x-text="activeMonth?.month" class="text-gray-700 dark:text-gray-200"></span>
      </div>
    </div>

    <div x-show="view === 'years'" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 scale-95" x-transition:enter-end="opacity-100 scale-100">
      <template x-for="yearData in historyData" :key="yearData.id">
        <div 
          @click="openMonths(yearData)" 
          class="group relative bg-white dark:bg-[#161616] rounded-2xl overflow-hidden cursor-pointer border border-gray-200 dark:border-white/10 hover:border-[#F5C518] transition-all duration-300 shadow-md hover:shadow-[0_0_20px_rgba(245,197,24,0.15)]"
        >
          <div class="h-64 overflow-hidden relative bg-gray-200 dark:bg-gray-800">
            <img :src="yearData.cover" onerror="this.src='https://placehold.co/600x400?text=No+Cover'" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
            <div class="absolute top-4 right-4 bg-[#F5C518] text-black font-black text-xl px-4 py-1.5 rounded-lg shadow-lg" x-text="yearData.year"></div>
            <div class="absolute bottom-0 left-0 w-full p-6 text-white transform translate-y-2 group-hover:translate-y-0 transition-transform duration-300">
              <h3 class="text-2xl font-bold mb-2" x-text="yearData.title"></h3>
            </div>
          </div>
          <div class="p-6">
            <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed" x-text="yearData.desc"></p>
            <div class="mt-4 flex items-center text-[#F5C518] text-sm font-semibold group-hover:translate-x-2 transition-transform duration-300">
              လအလိုက်ကြည့်ရန် <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
            </div>
          </div>
        </div>
      </template>
    </div>

    <div x-show="view === 'months'" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6" style="display: none;" x-transition:enter="transition ease-out duration-300 delay-100" x-transition:enter-start="opacity-0 translate-x-10" x-transition:enter-end="opacity-100 translate-x-0">
      <template x-if="activeYear">
        <template x-for="monthData in activeYear.months" :key="monthData.id">
          <div 
            @click="openGallery(monthData)"
            class="group bg-white dark:bg-[#161616] rounded-xl overflow-hidden cursor-pointer border border-gray-200 dark:border-white/10 hover:border-[#F5C518] transition-all duration-300 shadow-sm"
          >
            <div class="h-40 overflow-hidden relative bg-gray-200 dark:bg-gray-800">
              <img :src="monthData.cover" onerror="this.src='https://placehold.co/400x300?text=Kilo+Taxi'" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
              <div class="absolute inset-0 bg-black/50 group-hover:bg-black/30 transition-colors duration-300"></div>
              <div class="absolute inset-0 flex items-center justify-center">
                <h4 class="text-white text-2xl font-bold tracking-wider drop-shadow-lg" x-text="monthData.month"></h4>
              </div>
            </div>
            <div class="p-4 text-center">
              <p class="text-xs text-gray-500 dark:text-gray-400 group-hover:text-[#F5C518] transition-colors" x-text="monthData.title"></p>
            </div>
          </div>
        </template>
      </template>
    </div>

    <div x-show="view === 'gallery'" class="columns-1 md:columns-2 lg:columns-3 gap-6 space-y-6" style="display: none;" x-transition:enter="transition ease-out duration-300 delay-100" x-transition:enter-start="opacity-0 translate-y-10" x-transition:enter-end="opacity-100 translate-y-0">
      <template x-if="activeMonth">
        <template x-for="(imgSrc, index) in activeMonth.images" :key="index">
          <div class="break-inside-avoid relative group overflow-hidden rounded-xl cursor-zoom-in" @click="lightboxImg = imgSrc">
            <div class="bg-gray-200 dark:bg-gray-800 min-h-[150px] w-full flex items-center justify-center rounded-xl">
              <img 
                :src="imgSrc" 
                onerror="this.src='https://placehold.co/600x400?text=Image+Error'"
                class="w-full h-auto object-cover rounded-xl transition-transform duration-500 group-hover:scale-105" 
                loading="lazy"
              />
            </div>
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-colors duration-300 flex items-center justify-center opacity-0 group-hover:opacity-100">
               <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" /></svg>
            </div>
          </div>
        </template>
      </template>
    </div>

  </div>

  <div 
    x-show="lightboxImg !== ''" 
    x-transition.opacity
    class="fixed inset-0 z-[100] flex items-center justify-center bg-black/95 p-4 backdrop-blur-md"
    @click="lightboxImg = ''"
    style="display: none;"
    @keydown.escape.window="lightboxImg = ''"
  >
    <button class="absolute top-6 right-6 text-white/70 hover:text-[#F5C518] text-4xl font-bold transition-colors z-50">&times;</button>
    <img 
      :src="lightboxImg" 
      class="max-w-full max-h-[90vh] rounded-lg shadow-2xl object-contain"
      @click.stop
    />
  </div>
</section>

<script is:inline>
  document.addEventListener('alpine:init', () => {
    Alpine.data('historyGallery', function () {
      return {
        view: 'years', 
        historyData: [],
        activeYear: null,
        activeMonth: null,
        lightboxImg: '',

        init() {
          const rawData = this.$el.getAttribute('data-history');
          if (rawData) {
            this.historyData = JSON.parse(rawData);
          }
        },
        openMonths(yearData) {
          this.activeYear = yearData;
          this.view = 'months';
          this.scrollToTop();
        },
        openGallery(monthData) {
          this.activeMonth = monthData;
          this.view = 'gallery';
          this.scrollToTop();
        },
        goBack() {
          if (this.view === 'gallery') {
            this.view = 'months';
          } else if (this.view === 'months') {
            this.view = 'years';
            this.activeYear = null;
          }
          this.scrollToTop();
        },
        scrollToTop() {
          const section = document.getElementById('history');
          if (section) {
            window.scrollTo({
              top: section.offsetTop - 80,
              behavior: 'smooth'
            });
          }
        }
      }
    })
  });
</script>