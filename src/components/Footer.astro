  { name: "TikTok", url: "https://www.tiktok.com/@kilotaxiserviceofficial1?_r=1&_t=ZS-97XvUIWvRVk", icon: "M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5", color: "hover:bg-[#000000]" },
  { name: "YouTube", url: "https://youtube.com/@kilotaxiservice?si=cAh44V7xEu28kDsN", icon: "M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.42a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.42 8.6.42 8.6.42s6.88 0 8.6-.42a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.33 29 29 0 0 0-.46-5.33zM10.25 15.33V8.17L16.63 11.75z", color: "hover:bg-[#FF0000]" },
  { name: "Telegram", url: "https://t.me/kilo-taxi", icon: "M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z", color: "hover:bg-[#0088CC]" },
  // Viber icon အမှန်ကို ပြင်ထားပါသည်
  { name: "Viber", url: "viber://chat?number=09xxxxxxxxx", icon: "M16.14 18.66c-.4 1.15-1.2 1.6-2.14 1.6-2.9 0-5.85-2.05-8.5-5.3C2.86 11.66 1.7 8.36 1.7 5.6c0-.9.45-1.7 1.6-2.1C3.95 3 4.55 3 5.4 3c.75 0 1.45.15 2.15.55.9.5 1.5 1.4 1.8 2.55L10 8.6c.45 1.35.1 2.25-.8 3.15l-1.15 1.15c-.45.45-.3 1.25.15 1.75 1.1 1.25 2.5 2.5 3.8 3.75.45.45 1.25.6 1.7.15l1.15-1.15c.9-.9 1.8-1.25 3.15-.8l2.45 1.15c1.15.4 2.05 1 2.55 1.9.45.65.6 1.4.6 2.15-.05 1.05-.5 1.85-1.6 2.2z", color: "hover:bg-[#7360F2]" }
