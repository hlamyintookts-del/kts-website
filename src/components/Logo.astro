---
// src/components/Logo.astro
---
<div class="logo-container w-full h-full cursor-pointer">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 140 140" class="w-full h-full">
    <defs>
      <linearGradient id="chromeGrad" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#FFFFFF" />
        <stop offset="30%" stop-color="#B8B8B8" />
        <stop offset="50%" fill="#E8E8E8" stop-color="#E8E8E8" />
        <stop offset="70%" stop-color="#707070" />
        <stop offset="100%" stop-color="#999999" />
      </linearGradient>

      <radialGradient id="trueRedDialGrad" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#FF1E43" />
        <stop offset="70%" stop-color="#D60024" />
        <stop offset="100%" stop-color="#800012" />
      </radialGradient>

      <filter id="elementShadow" x="-20%" y="-20%" width="140%" height="140%">
        <feDropShadow dx="1" dy="1.5" stdDeviation="1" flood-opacity="0.9"/>
      </filter>
    </defs>

    <circle cx="70" cy="70" r="67" fill="url(#chromeGrad)" />
    <circle cx="70" cy="70" r="64" fill="#111115" />
    
    <circle cx="70" cy="70" r="61" fill="url(#trueRedDialGrad)" />
    
    <g class="dash-zone" stroke="#111115" stroke-width="0.4" paint-order="stroke fill">
      <rect x="67.9" y="14" width="12.2" height="7.5" rx="2.6" transform="rotate(-120, 70, 70)" fill="#00FF66" />
      <rect x="67.9" y="14" width="12.2" height="7.5" rx="2.6" transform="rotate(-98.18, 70, 70)" fill="#00FF66" />
      <rect x="67.9" y="14" width="12.2" height="7.5" rx="2.6" transform="rotate(-76.36, 70, 70)" fill="#00FF66" />
      <rect x="67.9" y="14" width="12.2" height="7.5" rx="2.6" transform="rotate(-54.55, 70, 70)" fill="#00FF66" />

      <rect x="67.9" y="14" width="12.2" height="7.5" rx="2.6" transform="rotate(-32.73, 70, 70)" fill="#FFEA00" />
      <rect x="67.9" y="14" width="12.2" height="7.5" rx="2.6" transform="rotate(-10.91, 70, 70)" fill="#FFEA00" />
      <rect x="67.9" y="14" width="12.2" height="7.5" rx="2.6" transform="rotate(10.91, 70, 70)" fill="#FFEA00" />
      <rect x="67.9" y="14" width="12.2" height="7.5" rx="2.6" transform="rotate(32.73, 70, 70)" fill="#FFEA00" />

      <rect x="67.9" y="14" width="12.2" height="7.5" rx="2.6" transform="rotate(54.55, 70, 70)" fill="#00E5FF" />
      <rect x="67.9" y="14" width="12.2" height="7.5" rx="2.6" transform="rotate(76.36, 70, 70)" fill="#00E5FF" />
      <rect x="67.9" y="14" width="12.2" height="7.5" rx="2.6" transform="rotate(98.18, 70, 70)" fill="#00E5FF" />
      <rect x="67.9" y="14" width="12.2" height="7.5" rx="2.6" transform="rotate(120, 70, 70)" fill="#00E5FF" />
    </g>
    
    <circle cx="70" cy="70" r="40" fill="none" stroke="#FFFFFF" stroke-width="1" opacity="0.15" />

    <g font-unicode="system-ui, -apple-system, sans-serif" font-weight="900" font-size="20" paint-order="stroke fill" filter="url(#elementShadow)">
      <text x="70" y="48" text-anchor="middle" fill="#00FF66" stroke="#000000" stroke-width="2">Kilo</text>
      
      <text x="90" y="74" text-anchor="middle" fill="#FFFFFF" stroke="#000000" stroke-width="2" letter-spacing="0.5">Taxi</text>
      
      <text x="70" y="98" text-anchor="middle" fill="#FFEA00" stroke="#000000" stroke-width="2" letter-spacing="0.5">Service</text>
    </g>
    
    <g class="needle-group" style="transform-origin: 70px 74px; transform: rotate(-45deg);">
      <line x1="70" y1="74" x2="36" y2="43" stroke="#FFFFFF" stroke-width="3.5" stroke-linecap="round" filter="url(#elementShadow)" />
      <circle cx="70" cy="74" r="5" fill="#FFEA00" stroke="#111111" stroke-width="1" />
      <circle cx="70" cy="74" r="2" fill="#FFFFFF" />
    </g>
  </svg>
</div>

<style>
  /* Hover 3D Smooth Scale Effect */
  .logo-container {
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  .logo-container:hover {
    transform: scale(1.08);
  }

  /* Needle Smooth Fast Rotation on Hover */
  .needle-group {
    transition: transform 1.2s cubic-bezier(0.25, 0.8, 0.25, 1);
  }
  .logo-container:hover .needle-group {
    transform: rotate(115deg) !important;
  }
</style>